# Docky - Configuration
# Copiez ce fichier en .env et modifiez les valeurs
# cp .env.example .env

# Version des images (latest, test, ou un numéro de version comme 0.0.1)
DOCKY_VERSION=latest

# Port de l'orchestrateur (interface web)
DOCKY_PORT=8000

# Port de l'agent (API)
DOCKY_AGENT_PORT=8080

# Clé API de l'agent (CHANGEZ CECI! générez une clé avec: openssl rand -hex 32)
DOCKY_AGENT_API_KEY=change-this-to-your-secret-key